# tests/hw/boards.local.conf — your board → serial-port map for the
# hardware smoke layer (`./tests/run.sh hw`).
#
# Copy this file to `boards.local.conf` (gitignored) and edit it for your
# bench. `run.sh hw` runs every tests/hw/NN_*.sh against EACH board listed
# here. Adding a new board is one line — no test-script changes needed.
#
# Format (whitespace-separated), one board per line:
#     <board_id>            <serial_port>     [baud]
# Lines starting with # are ignored; baud defaults to 1500000.
#
# Tip (WSL + usbipd): after `usbipd attach`, each board shows up as its own
# /dev/ttyUSB*. Run `pio device list` to see which is which.

pke8721daf-c13-f10    /dev/ttyUSB0    1500000
pke8710ecf-c53-f20    /dev/ttyUSB1    1500000
pke8713ecm-va4-n43    /dev/ttyUSB2    1500000
